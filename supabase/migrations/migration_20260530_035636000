
-- Re-apply explicit RLS policies for all CMS tables
-- site_settings
drop policy if exists "Service write site_settings" on site_settings;
create policy "Allow insert site_settings"  on site_settings for insert  with check (true);
create policy "Allow update site_settings"  on site_settings for update  using (true) with check (true);
create policy "Allow delete site_settings"  on site_settings for delete  using (true);

